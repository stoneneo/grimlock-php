{
  "name": "gorilla-soft/grimlock",
  "description": "Grimlock - Libraries & Utilities for PHP",
  "homepage": "https://grimlock.gorilla-soft.com",
  "version": "0.0.1",
  "type": "library",
  "keywords": [ "gorilla", "soft", "grimlock", "php", "libraries", "utilities" ],
  "license": "MIT",
  "authors": [
    {
      "name": "Rubén Darío Huamaní Ucharima",
      "email": "rhuamani@gorilla-soft.com",
      "homepage": "https://www.gorilla-soft.com",
      "role": "Architect"
    }
  ],
  "support": {
    "email": "grimlock-php@gorilla-soft.com"
  },
  "require": {
    "guzzlehttp/guzzle": "^7.10.0",
    "ext-pdo": "*",
    "dompdf/dompdf" : "v2.0.4",
    "phpmailer/phpmailer" : "v6.9.1",
    "ext-json": "*",
    "ext-curl": "*",
    "google/auth": "^1.50.1",
    "monolog/monolog": "^3.10.0",
    "php": ">=8.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5.63"
  },
  "autoload": {
    "psr-4": {
      "GorillaSoft\\Grimlock\\": "src/",
      "GorillaSoft\\Grimlock\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "coverage": "phpunit --coverage-html=coverage --coverage-text"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
